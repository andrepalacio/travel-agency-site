generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Para textos fijos del Home y Globales
model PageSettings {
  id    String @id @default("home")
  data  Json
}

model Experience {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  isFeatured   Boolean  @default(false)
  imageUrl     String   // URL de Vercel Blob
  intro        Json     // Slogan, días/noches, descripción
  itinerary    Json     // Mapa, salida/llegada, imagen principal
  amenities    Json     // Inclusiones, comodidades, requisitos
  createdAt    DateTime @default(now())
  updatedAt    DateTime? @updatedAt
}

model Cruise {
  id          String   @id @default(cuid())
  name        String
  description String
  imageUrl    String
  ctaText     String
  order       Int      @default(0)
}

model Lead {
  id                String   @id @default(cuid())
  nombre            String
  apellido          String
  email             String
  fechaNacimiento   String   // Guardado como string para coincidir con el input type="date"
  celular           String?  // Opcional en tu formulario
  interesSeleccionado String   // Guardará el valor de "Experiencia" o "Crucero"
  createdAt         DateTime @default(now())
  updatedAt         DateTime? @updatedAt
}

model PotentialLead {
  id                String   @id @default(cuid())
  nombre            String
  email             String
  brochureId        Int
  fechaNotificacion DateTime @default(now())
}

model Brochure {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  fileUrl     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime? @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name    String
  last_name  String
  email     String   @unique
  password  String   // Hash de la contraseña
  rol       String   @default("admin") // admin, editor, etc.
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt
}